generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

enum RegistrationStatus {
  pending
  approved
  rejected
}

enum Gender {
  male
  female
}

enum UserRole {
  admin
  member
  user
  volunteer
  support
  donor
}

model Member {
  id                   String             @id @default(cuid())
  firstName            String
  middleName           String?
  surname              String
  gender               Gender
  currentAddress       String
  city                 String?
  country              String?            @default("Sierra Leone")
  admissionNumber      String?
  dateOfEntry          DateTime
  dateOfExit           DateTime?
  email                String?            @unique
  phone                String             @unique
  registrationAmount   Float
  transactionReference String
  systemReference      String             @unique
  status               RegistrationStatus @default(pending)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Link to User account - relation defined here
  userId               String?            @unique
  user                 User?              @relation(fields: [userId], references: [id])

  transactions Transaction[]

  @@index([status])
  @@index([email])
  @@index([phone])
  @@index([systemReference])
  @@index([city])
  @@index([country])
  @@index([userId])
}

model Transaction {
  id                   String   @id @default(cuid())
  memberId             String
  memberName           String
  phone                String
  amount               Float
  transactionReference String
  systemReference      String
  type                 String   @default("registration")
  description          String?
  createdAt            DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([transactionReference])
  @@index([systemReference])
  @@index([type])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         UserRole @default(user)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Link to Member profile - NO @relation attributes here, just the field
  memberId     String?  @unique
  member       Member?  // This creates the relation without extra attributes

  @@index([email])
  @@index([role])
  @@index([memberId])
}